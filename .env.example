# Переменные окружения для WheatMagnateBot

# Токен Discord бота (обязательно для команд и уведомлений)
DISCORD_BOT_TOKEN=ваш_токен_здесь

# ID канала Discord (обязательно, куда бот пишет статус и слушает команды)
DISCORD_CHANNEL_ID=ваш_channel_id_здесь

# ID канала Discord для чата (опционально, для пересылки сообщений из Minecraft)
DISCORD_CHAT_CHANNEL_ID=ваш_chat_channel_id_здесь

# Discord user ID владельца (bdiev_). Microsoft login links are sent only to this user's DM.
DISCORD_OWNER_ID=ваш_discord_user_id_здесь

# Игнорируемые usernames для чата (опционально, через запятую, сообщения от этих игроков/ботов не пересылаются)
IGNORED_CHAT_USERNAMES=bot1,bot2

# Имя пользователя Minecraft (опционально, по умолчанию 'WheatMagnate')
MINECRAFT_USERNAME=ваш_username_здесь

# Версия Minecraft (опционально, по умолчанию auto-detect)
MINECRAFT_VERSION=1.20.1

# Тип авторизации (опционально, 'offline' или 'microsoft', по умолчанию 'microsoft')
MINECRAFT_AUTH=microsoft

# Сессия Minecraft (опционально, для сохранения аутентификации)
MINECRAFT_SESSION=ваша_сессия_здесь

# Опционально: отключить бота (true/false)
DISABLE_BOT=false

# Опционально: ID сообщения статуса (для обновления существующего сообщения)
STATUS_MESSAGE_ID=ваш_status_message_id_здесь

# URL базы данных PostgreSQL (для сохранения сессии и других данных)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Gemini API for the in-game !gpt <question> command.
# Create a key in Google AI Studio. Only whitelisted Minecraft players can use it.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini model override.
GEMINI_MODEL=gemini-2.5-flash
