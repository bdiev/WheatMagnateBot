# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_CHAT_CHANNEL_ID=
DISCORD_DM_CATEGORY_ID=
DISCORD_OWNER_ID=
DISCORD_LOGIN_RETRY_MS=15000
DISCORD_ATTACHMENT_LIMIT_BYTES=25165824
IGNORED_CHAT_USERNAMES=player_one,player_two

# Database and site
DATABASE_URL=
SITE_ADMIN_USERNAME=
SITE_ADMIN_PASSWORD=
# Used only for one local CLI invocation; do not persist a value here.
SITE_ADMIN_CLI_PASSWORD=
SITE_PORT=3080
DEFAULT_SITE_WHISPER_USERNAME=example_player
# Public origin used to validate mutating browser requests (required behind an HTTPS proxy).
SITE_PUBLIC_ORIGIN=http://localhost:3080
# Only enable when requests come exclusively through a trusted reverse proxy.
SITE_TRUST_PROXY=false
SITE_COOKIE_SECURE=false
SITE_SESSION_MAX_AGE_SECONDS=2592000
SITE_LOGIN_MAX_ATTEMPTS=20
SITE_LOGIN_MAX_FAILURES=5
SITE_LOGIN_WINDOW_SECONDS=900
SITE_LOGIN_BLOCK_SECONDS=900
SITE_REGISTER_MAX_ATTEMPTS=10
SITE_REGISTER_MAX_FAILURES=5
SITE_REGISTER_WINDOW_SECONDS=3600
SITE_REGISTER_BLOCK_SECONDS=1800

# Minecraft
MINECRAFT_HOST=minecraft.example.org
MINECRAFT_PORT=25565
MINECRAFT_USERNAME=WheatMagnate
MINECRAFT_ADMIN_USERNAME=ServerAdmin
MINECRAFT_COMMAND_BOT_USERNAME=CommandBot
MINECRAFT_AUTH=microsoft
MINECRAFT_SERVER_NAME=Example Minecraft Server
MINECRAFT_PROFILES_FOLDER=data/auth-cache
# Optional JSON session object. Treat this value as a secret.
MINECRAFT_SESSION=
MINECRAFT_RECONNECT_TIMEOUT_MS=15000
MINECRAFT_CONNECT_TIMEOUT_MS=20000
MINECRAFT_PRIVATE_MESSAGE_LENGTH=180

# Obsidian farm initial target (used when the database has no saved target)
FARM_TARGET_X=0
FARM_TARGET_Y=64
FARM_TARGET_Z=0
FARM_CAULDRON_RADIUS=5
FARM_STATS_UPDATE_INTERVAL_MS=30000
FARM_STATS_WATCHDOG_INTERVAL_MS=300000

# Gemini
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash-lite
GEMINI_MODEL=
GEMINI_FALLBACK_MODEL=
GEMINI_ENABLED=true

# Runtime behavior
DANGER_RADIUS_BLOCKS=300
WHITELIST_MODE=true
AUTO_EAT=true
CHILD_PUBLIC_SPEECH=true
WM_COMMAND_COOLDOWN_MS=20000
WM_MAX_QUESTION_LENGTH=300
WM_MAX_RESPONSE_LENGTH=900
WM_MAX_OUTPUT_TOKENS=300
WM_CHAT_CHUNK_LENGTH=190
WHISPER_TTL_MS=600000
WHISPER_MARK_TTL_MS=3000
PENDING_CHAT_DELAY_MS=1500
OUTBOUND_WHISPER_TTL_MS=5000
SITE_WHISPER_TTL_MS=600000
DEBUG_LOGS=false
DISABLE_BOT=false
