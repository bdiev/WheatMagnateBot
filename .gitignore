# Environment files (keep the sanitized template tracked)
.env
.env.*
!.env.example

# Installed dependencies
node_modules/
site/node_modules/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary files
*.tmp
*.temp
.tmp/
tmp/
temp/

# Authentication and runtime caches
auth-cache/
data/auth-cache/

# Local runtime data
data/bot_public_chat_status.json
data/player_head_emojis.json
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal

# Site-local configuration
site/data/config.local.json
site/data/*.local.json
site/config.local.*
